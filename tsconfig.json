{
    "include": ["src/**/*.ts"],
    "exclude": [],
    "compilerOptions": {
        "experimentalDecorators": true,
        "strict": true,
        "target": "es2020",
        "moduleResolution": "node",
        "strictPropertyInitialization": false,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "./",
        "declarationMap": true
    }
}