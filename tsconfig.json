{
    "include": ["src/**/*.ts"],
    "compilerOptions": {
        "experimentalDecorators": true,
        "strict": true,
        "target": "es2020",
        "moduleResolution": "node",
        "skipLibCheck": true,
        "strictPropertyInitialization": false,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "dist",
        "declarationMap": true
    }
}